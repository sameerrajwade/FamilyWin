{
  "expo": {
    "name": "FamilyWin",
    "slug": "familywin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C63FF"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundColor": "#6C63FF"
      },
      "package": "com.familywin.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "notification": {
        "icon": "./assets/notification-icon.png",
        "color": "#6C63FF",
        "androidMode": "default"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.familywin.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6C63FF",
          "sounds": []
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "FamilyWin uses your photos to set profile pictures for family members.",
          "cameraPermission": "FamilyWin uses your camera to take profile photos.",
          "microphonePermission": false
        }
      ]
    ],
    "scheme": "familywin",
    "experiments": {
      "typedRoutes": true
    }
  }
}
